<odoo>
    <record id="view_book_borrow_history_wizard_form" model="ir.ui.view">
        <field name="name">book.borrow.history.wizard.form</field>
        <field name="model">book.borrow.history.wizard</field>
        <field name="arch" type="xml">
            <form string="Book Borrow History">
                <sheet>
                    <group>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="student_ids" widget="many2many_tags"/>
                        <field name="book_ids" widget="many2many_tags"/>
                        <field name="is_return_date"/>
                    </group>
                    <footer>
                        <button string="Print Report" type="object" name="print_book_borrow_history"
                                class="btn-primary" groups="base.group_system"/>

                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="book_borrow_history_wizard_action" model="ir.actions.act_window">
        <field name="name">Book Borrow History</field>
        <field name="res_model">book.borrow.history.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>


    <menuitem id="book_borrow_history_wizard_menu_root" name="Reporting" parent="menu_root"/>

    <menuitem id="book_history" name="Book History"
              parent="book_borrow_history_wizard_menu_root"
              action="book_borrow_history_wizard_action"
              groups="library_management_sunil.group_librarian"/>
</odoo>