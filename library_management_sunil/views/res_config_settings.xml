<odoo>
    <record id="res_config_settings_view_form_custom" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Add after Performance block -->
            <xpath expr="//block[@name='performance']" position="before">
                <block title="sunil record" id="sunil_record">
                    <setting>
                        <field name="is_Active_fine"/>
                        <field name="fine_per_days"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>