<odoo>
    <data>
        <record id="book_kanban_view" model="ir.ui.view">
            <field name="name">book.kanban</field>
            <field name="model">book.book</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_small_column">
                    <field name="name"/>
                    <field name="barcode"/>
                    <field name="available_copies"/>
                    <field name="borrow_price_per_day"/>
                    <field name="state"/>

                    <templates>
                        <!-- Change the template name from 'kanban-box' to 'card' -->
                        <t t-name="card">
                            <div class="oe_kanban_card">
                                <strong>
                                    <t t-esc="record.name.value"/>
                                </strong>
                                <div>
                                    <span>Barcode:
                                        <t t-esc="record.barcode.value"/>
                                    </span>
                                </div>
                                <div>
                                    <span>Available Copies:
                                        <t t-esc="record.available_copies.value"/>
                                    </span>
                                </div>
                                <div>
                                    <span>Price/Day:
                                        <t t-esc="record.borrow_price_per_day.value"/>
                                    </span>
                                </div>
                                <div>
                                    <span>Status:
                                        <t t-esc="record.state.value"/>
                                    </span>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="book_list_view" model="ir.ui.view">
            <field name="name">book.list</field>
            <field name="model">book.book</field>
            <field name="arch" type="xml">
                <list string="book">
                    <field name="name"/>
                    <field name="barcode"/>
                    <field name="currency_id"/>
                    <field name="state"/>
                    <field name="available_copies"/>
                    <field name="stock"/>
                    <field name="borrow_price_per_day"/>
                    <field name="maximum_day_limit"/>
                </list>
            </field>
        </record>


        <record id="booking_form_view" model="ir.ui.view">
            <field name="name">book.form</field>
            <field name="model">book.book</field>
            <field name="arch" type="xml">
                <form string="book">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_borrow_history" type="object" class="oe_stat_button">
                                <field name="borrowed_count" widget="statinfo" string="Borrow History"/>
                            </button>

                            <button type="object" class="oe_stat_button">
                                <field name="available_display" widget="statinfo" string="Available Books"/>
                            </button>
                        </div>

                        <header>
                            <button name="action_publish" type="object" string="Publish" class="btn-primary"
                                    invisible="state == 'published'"/>

                            <button name="action_unpublish" type="object" string="Unpublish" class="btn-primary"
                                    invisible="state == 'unpublished'"/>

                            <field name="state" widget="statusbar"
                                   statusbar_visible="published,unpublished"/>

                        </header>

                        <group>
                            <group>
                                <field name="name"/>
                                <field name="barcode"/>
                                <field name="currency_id"/>
                                <field name="state"/>
                                <field name="available_copies"/>
                            </group>
                            <group>
                                <field name="category_id"/>
                                <field name="stock"/>
                                <field name="available_display"/>
                                <field name="borrow_price_per_day"/>
                                <field name="borrowed_count"/>
                                <field name="maximum_day_limit"/>
                            </group>
                        </group>

                        <notebook>

                            <page string="Description">
                                <field name="description"/>
                            </page>

                            <page string="cover image">
                                <field name="cover_image" widget="image"/>
                            </page>

                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="book_action" model="ir.actions.act_window">
            <field name="name">Book</field>
            <field name="res_model">book.book</field>
            <field name="view_mode">kanban,form</field>
        </record>

        <menuitem id="book_menu_root" name="Books"
                  parent="menu_root"
                  action="book_action"/>
    </data>
</odoo>
