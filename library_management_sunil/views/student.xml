<odoo>
    <record id="student_list_view" model="ir.ui.view">
        <field name="name">student.list</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="gender"/>
            </list>
        </field>
    </record>

    <record id="student_form_view" model="ir.ui.view">
        <field name="name">student.form</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                        <div name="button_box">
                            <button name="action_view_borrow_history_student" type="object" class="oe_stat_button" icon="fa-laptop">
                                <field name="borrow_count" widget="statinfo" string="Borrow History"/>
                            </button>
                        </div>

                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="gender"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

<!--    Kanban-->
    <record id="student_kanban_view" model="ir.ui.view">
        <field name="name">student.inherit.kanban.views</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="gender"/>

                <templates>
                    <t t-name="menu">
                        <t t-if="widget.editable"><a role="menuitem" type="open" class="dropdown-item">Edit</a></t>
                        <t t-if="widget.deletable"><a role="menuitem" type="delete" class="dropdown-item">Delete</a></t>

                    </t>

                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">

                            <!-- Header -->
                            <div class="o_kanban_header">
                                <strong>
                                    <field name="name"/>
                                </strong>

                                <t t-if="record.phone.value">
                                    <span class="badge bg-secondary float-end">
                                        <field name="phone"/>
                                    </span>
                                </t>

                            </div>

                            <!-- Body -->
                            <div class="o_kanban_content mt-2">
                                <div>
                                    <span class="badge text-bg-info">
                                        <field name="email"/>
                                    </span>

                                    <t t-if="record.gender.raw_value == 'male'">
                                        <span class="badge text-bg-success float-end">Male</span>
                                    </t>

                                    <t t-else="">
                                        <span class="badge text-bg-danger float-end">Female</span>
                                    </t>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="student_action" model="ir.actions.act_window">
        <field name="name">student</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_member':'student'}</field>
        <field name="domain">[('member','=','student')]</field>
    </record>

    <record id="action_student_list" model="ir.actions.act_window.view">
        <field name="view_mode">list</field>
        <field name="view_id" ref="student_list_view"/>
        <field name="act_window_id" ref="student_action"/>
    </record>

    <record id="action_student_form" model="ir.actions.act_window.view">
        <field name="view_mode">form</field>
        <field name="view_id" ref="student_form_view"/>
        <field name="act_window_id" ref="student_action"/>
    </record>

    <record id="student_inherit_kanban_views" model="ir.actions.act_window.view">
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="student_kanban_view"/>
        <field name="act_window_id" ref="student_action"/>
    </record>

    <menuitem id="student_menu_root" name="Students" parent="menu_root"
              action="student_action"/>

</odoo>

