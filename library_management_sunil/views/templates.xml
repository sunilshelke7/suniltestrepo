    <template id="website_book_menu_view" name="Book Menu View">
        <t t-call="website.layout">
            <section class="container py-5">
                <div class="row justify-content-center">
                    <h3 class="mb-4 text-center">Welcome to Ganpat university Library</h3>
                    <form action="/book/form" method="get">
                        <p class="my-3">
                            <button type="submit" class="btn btn-primary">New</button>
                        </p>
                    </form>
                    <table class="table table-bordered table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Name</th>
                                <th>Available Copies</th>
                                <th>Stock</th>
                                <th>Borrow Price</th>
                                <th>Maximum Day Limit</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="books" t-as="book">
                                <tr>
                                    <td>
                                        <span t-field="book.name"/>
                                    </td>

                                    <td>
                                        <span t-field="book.available_copies"/>
                                    </td>
                                    <td>
                                        <span t-field="book.stock"/>
                                    </td>
                                    <td>
                                        <span t-field="book.borrow_price_per_day"/>
                                    </td>
                                    <td>
                                        <span t-field="book.maximum_day_limit"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </section>
        </t>
    </template>

    <template id="book_form_view" name="Book Form">
        <t t-call="website.layout">
            <section class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-md-6 col-lg-5">
                        <div class="card shadow rounded-3 border-0">
                            <div class="card-body p-4">
                                <h3 class="mb-4 text-center">Create New Book</h3>
                                <form action="/book/create" method="post">
                                    <div class="mb-3">
                                        <label class="form-label">Name</label>
                                        <input type="text" name="name" required="required" class="form-control"/>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Available Copies</label>
                                        <input type="number" name="available_copies" class="form-control"/>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Stock</label>
                                        <input type="number" name="stock" required="required" class="form-control"/>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Borrow Price</label>
                                        <input type="number" name="borrow_price_per_day" class="form-control"/>
                                    </div>
                                    <div class="mb-4">
                                        <label class="form-label">Maximum Day Limit</label>
                                        <input type="number" name="maximum_day_limit" class="form-control"/>
                                    </div>
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary">Submit</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </t>
    </template>


    <template id="portal_my_orders_template">
        <t t-call="portal.portal_layout">
            <div class="container">
                <h2>Your Orders</h2>
                <table class="table">
                    <tr>
                        <th>Book Name</th>
                        <th>User</th>
                    </tr>

                    <t t-foreach="orders"
                       t-as="order">
                        <tr>
                            <td>
                                <t t-esc="order.name"/>
                            </td>
                            <td>
                                <t t-esc="order.user_id.name"/>
                            </td>
                        </tr>
                    </t>
                </table>
            </div>
        </t>
    </template>

