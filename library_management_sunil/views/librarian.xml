<odoo>
    <record id="librarian_list_view" model="ir.ui.view">
        <field name="name">librarian.list</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="gender"/>
            </list>
        </field>
    </record>

    <record id="librarian_form_view" model="ir.ui.view">
        <field name="name">librarian.form</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                     <div name="button_box">
                            <button name="action_view_borrow_history" type="object" class="oe_stat_button">
                                <field name="borrow_count" widget="statinfo" string="Borrow History"/>
                            </button>
                        </div>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="gender"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="librarian_action" model="ir.actions.act_window">
        <field name="name">librarian</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_member':'librarian'}</field>
        <field name="domain">[('member','=','librarian')]</field>
    </record>

    <record id="action_librarian_list" model="ir.actions.act_window.view">
        <field name="view_mode">list</field>
        <field name="view_id" ref="librarian_list_view"/>
        <field name="act_window_id" ref="librarian_action"/>
    </record>

    <record id="action_librarian_form" model="ir.actions.act_window.view">
        <field name="view_mode">form</field>
        <field name="view_id" ref="librarian_form_view"/>
        <field name="act_window_id" ref="librarian_action"/>
    </record>

    <menuitem id="librarian_menu_root" name="Librarians" parent="menu_root"
              action="librarian_action" groups="library_management_sunil.group_librarian"/>

</odoo>

