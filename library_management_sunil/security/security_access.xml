<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record model="ir.module.category" id="module_category_library">
            <field name="name">Library Management</field>
            <field name="sequence">10</field>
        </record>

        <record model="res.groups.privilege" id="res_groups_privilege_library">
            <field name="name">Library</field>
            <field name="category_id" ref="module_category_library"/>
        </record>

        <record id="group_student" model="res.groups">
            <field name="name">Student</field>
            <field name="privilege_id" ref="res_groups_privilege_library"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_librarian" model="res.groups">
            <field name="name">Librarian</field>
            <field name="privilege_id" ref="res_groups_privilege_library"/>
            <field name="implied_ids" eval="[(4, ref('group_student'))]"/>
        </record>

        <record id="group_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="sequence">22</field>
            <field name="privilege_id" ref="res_groups_privilege_library"/>
            <field name="implied_ids" eval="[(4, ref('group_librarian'))]"/>
        </record>

        <record id="borrow_request_librarian_rule" model="ir.rule">
            <field name="name">Librarian Own Borrow Request</field>
            <field name="model_id" ref="model_borrow_request_borrow_request"/>
            <field name="groups" eval="[(4, ref('library_management_sunil.group_librarian'))]"/>
            <field name="domain_force">[('librarian_id','=',user.partner_id.id)]</field>
        </record>

        <record id="borrow_request_student_rule" model="ir.rule">
            <field name="name">student Own Borrow Request</field>
            <field name="model_id" ref="model_borrow_request_borrow_request"/>
            <field name="groups" eval="[(4, ref('library_management_sunil.group_student'))]"/>
            <field name="domain_force">[('student_id','=',user.partner_id.id)]</field>
        </record>

        <record id="borrow_request_admin_rule" model="ir.rule">
            <field name="name">Admin All Borrow Requests</field>
            <field name="model_id" ref="model_borrow_request_borrow_request"/>
            <field name="groups" eval="[(4, ref('library_management_sunil.group_admin'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>

        <record id="librarian_own_record_rule" model="ir.rule">
            <field name="name">Librarian Can See Only Own Record</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('library_management_sunil.group_librarian'))]"/>
            <field name="domain_force">[('id', '=', user.partner_id.id)]</field>
        </record>

         <record id="admin_record_rule" model="ir.rule">
            <field name="name">admin can see all records</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('library_management_sunil.group_admin'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>

    </data>
</odoo>