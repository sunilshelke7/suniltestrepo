<odoo>
    <record id="view_borrow_cancel_wizard_form" model="ir.ui.view">
        <field name="name">borrow.cancel.wizard.form</field>
        <field name="model">borrow.cancel.wizard</field>
        <field name="arch" type="xml">

            <form>
                <group>
                    <field name="cancellation_reason"/>
                </group>
                <footer>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary"/>

                    <button string="Cancel" class="btn-primary"/>
                </footer>

            </form>

        </field>
    </record>
</odoo>